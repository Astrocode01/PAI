#include <Arduino.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);
int rowPins[4] = {19, 18, 5, 17};
int colPins[4] = {16, 4, 0, 2};
char keys[4][4] = {
{'1','2','3','A'},
{'4','5','6','B'},
{'7','8','9','C'},
{'*','0','#','D'}
};
QueueHandle_t keyQueue;

void keypadTask(void *pvParameters) {
char key;
while (1) {
for (int r = 0; r < 4; r++) {
digitalWrite(rowPins[r], LOW);
for (int c = 0; c < 4; c++) {
if (digitalRead(colPins[c]) == LOW) {
key = keys[r][c];
xQueueSend(keyQueue, &key, portMAX_DELAY);
vTaskDelay(300 / portTICK_PERIOD_MS);
}
}
digitalWrite(rowPins[r], HIGH);
}
vTaskDelay(10 / portTICK_PERIOD_MS);
}
}
void displayTask(void *pvParameters) {
char receivedKey;
display.clearDisplay();
display.setTextSize(2);
display.setTextColor(WHITE);
display.setCursor(0,0);
display.println("Press Key:");
display.display();
while (1) {
if (xQueueReceive(keyQueue, &receivedKey, portMAX_DELAY)) {
display.clearDisplay();
display.setCursor(0,0);
display.println("Pressed:");
display.setCursor(0,30);
display.print(receivedKey);
display.display();
}
}
}

void setup() {
Serial.begin(115200);
for (int i = 0; i < 4; i++) {
pinMode(rowPins[i], OUTPUT);
digitalWrite(rowPins[i], HIGH);
}
for (int i = 0; i < 4; i++) {
pinMode(colPins[i], INPUT_PULLUP);
}
Wire.begin(21, 22);
if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
while (1);
}
keyQueue = xQueueCreate(5, sizeof(char));
xTaskCreatePinnedToCore(keypadTask, "Keypad Task", 2048, NULL, 1, NULL, 0);
xTaskCreatePinnedToCore(displayTask, "Display Task", 4096, NULL, 1, NULL, 1);
}
void loop() {
}














































